#!/bin/bash
#
# Lab work #6, variant 7 - Process information script
# Author: Student Full Name (FIO)
# Description: Allows user to view and inspect system processes
#

# --- Configuration -----------------------------------------------------------
FIO="SG"  # Developer initials (change to your own)
SCRIPT_NAME="$(basename "$0")"
SCRIPT_DIR="$(dirname "$0")"
# Try to get absolute path; if fails, use relative
SCRIPT_PATH_ABS="$(cd "$SCRIPT_DIR" 2>/dev/null && pwd -P)/$SCRIPT_NAME" || SCRIPT_PATH_ABS="$0"
START_TIME_SECONDS="$SECONDS"
START_TIME_RAW="$(date '+%d-%m-%Y %H:%M:%S (%Z)')"

# Temporary file management
TMP_DIR="${SCRIPT_DIR}"
TMP_FILE=""
if [[ ! -w "$TMP_DIR" ]]; then
    TMP_DIR="/tmp"
fi
# Will be created via mktemp later, after trap is set

# Log files (for --d mode)
LOG_ALL=""
LOG_OUT=""
LOG_ERR=""
LOG_MODE=""

# Flags from command line
FLAG_D=0
FLAG_V=0
FLAG_S=0
FLAG_K=0
FLAG_H=0
FLAG_C=""

# Return codes
RC_NORMAL=0
RC_SIGINT=2
RC_SIGQUIT=3
RC_SIGTERM=15
RC_C_NOARG=20
RC_C_SUCCESS=21
RC_S_INSTANCE=22
RC_H_EXIT=23

# --- Functions ---------------------------------------------------------------

# Cleanup: remove temporary file and exit
cleanup() {
    local exit_code=$1
    local reason="$2"
    if [[ -n "$TMP_FILE" && -f "$TMP_FILE" ]]; then
        rm -f "$TMP_FILE"
    fi
    if [[ -n "$reason" ]]; then
        echo "Script terminated: $reason" >&2
    fi
    exit "$exit_code"
}

# Error handler for commands
check_error() {
    local cmd="$1"
    local errcode=$?
    if [[ $errcode -ne 0 ]]; then
        echo "ERROR: Command '$cmd' failed with code $errcode" >&2
    fi
    return $errcode
}

# Show process details by PID
show_process_info() {
    local pid="$1"
    if [[ -z "$pid" || ! -d "/proc/$pid" ]]; then
        echo "Process $pid does not exist or not accessible." >&2
        return 1
    fi
    echo "--- Detailed information for PID $pid ---"
    ps -p "$pid" -o pid,tty,stat,lstart,comm,args | sed 's/^/  /'
    # If lstart not available, fallback to start
    if [[ $? -ne 0 ]]; then
        ps -p "$pid" -o pid,tty,stat,start,comm,args | sed 's/^/  /'
    fi
}

# List processes based on filter
list_processes() {
    local filter_type="$1"
    local filter_value="$2"
    local ps_cmd="ps -e -o pid,user,group,tty,comm,args"  # default all processes

    case "$filter_type" in
        user)
            ps_cmd="ps -u $filter_value -o pid,user,group,tty,comm,args 2>/dev/null"
            ;;
        group)
            ps_cmd="ps -g $filter_value -o pid,user,group,tty,comm,args 2>/dev/null"
            ;;
        terminal)
            ps_cmd="ps -t $filter_value -o pid,user,group,tty,comm,args 2>/dev/null"
            ;;
        all|"")
            ps_cmd="ps -e -o pid,user,group,tty,comm,args"
            ;;
        *)
            echo "Invalid filter type" >&2
            return 1
            ;;
    esac

    echo "Process list (filter: $filter_type $filter_value):"
    eval "$ps_cmd" | {
        local header=""
        local count=0
        while IFS= read -r line; do
            if [[ $count -eq 0 ]]; then
                header="$line"
                echo "$header"
                echo "-----------------------------------------------------------------------"
            else
                echo "$line"
            fi
            ((count++))
        done
        if [[ $count -le 1 ]]; then
            echo "No processes found."
        fi
    }
    check_error "ps"
}

# Change current directory
change_directory() {
    local newdir="$1"
    if [[ -z "$newdir" ]]; then
        echo "Current directory: $(pwd)"
        return 0
    fi
    if cd "$newdir" 2>/dev/null; then
        echo "Directory changed to: $(pwd)"
    else
        echo "ERROR: Cannot change to directory '$newdir'" >&2
        return 1
    fi
}

# --- Signal handlers ---------------------------------------------------------

handle_sigint() {
    echo
    read -p "Really terminate script? (y/n) " answer
    if [[ "$answer" == "y" || "$answer" == "Y" ]]; then
        cleanup $RC_SIGINT "Interrupted by user (SIGINT)"
    else
        echo "Continuing..."
    fi
}

handle_sigquit() {
    echo "Received SIGQUIT" >&2
    cleanup $RC_SIGQUIT "SIGQUIT received"
}

handle_sigterm() {
    echo "Received SIGTERM" >&2
    cleanup $RC_SIGTERM "SIGTERM received"
}

handle_sigusr1() {
    local current_time="$SECONDS"
    local total_time=$((current_time - START_TIME_SECONDS))
    local ps_time=$(ps -p $$ -o time= 2>/dev/null)
    echo "--- SIGUSR1 ---"
    echo "Start time: $START_TIME_RAW"
    echo "Total elapsed time (wall clock): ${total_time}s"
    echo "CPU time used by script: ${ps_time:-N/A}"
}

handle_sigusr2() {
    echo "--- SIGUSR2: Open files for script (PID $$) ---"
    if command -v lsof >/dev/null 2>&1; then
        lsof -p $$ 2>/dev/null | head -20 | sed 's/^/  /'
    else
        echo "lsof not available, using fstat if possible:"
        fstat -p $$ 2>/dev/null | head -20 | sed 's/^/  /' || echo "Cannot list open files."
    fi
}

# --- Command line options processing -----------------------------------------

# Function to handle --c separately
handle_c_option() {
    local dir="$1"
    if [[ -z "$dir" ]]; then
        echo "ERROR: --c requires directory argument" >&2
        cleanup $RC_C_NOARG "Missing argument for --c"
    fi
    if [[ ! -d "$dir" ]]; then
        echo "ERROR: Directory '$dir' does not exist" >&2
        cleanup $RC_C_NOARG "Invalid directory for --c"
    fi
    echo "Searching for temporary files in: $dir"
    # Find files matching pattern (script's temp files with initials)
    local temp_files=$(find "$dir" -maxdepth 1 -type f -name "*${FIO}*.tmp" -o -name "script_${FIO}.*" 2>/dev/null)
    if [[ -z "$temp_files" ]]; then
        echo "No temporary files found."
    else
        echo "Found temporary files:"
        echo "$temp_files"
        read -p "Delete these files? (y/n) " ans
        if [[ "$ans" == "y" || "$ans" == "Y" ]]; then
            rm -f $temp_files
            echo "Files deleted."
        else
            echo "Deletion cancelled."
        fi
    fi
    cleanup $RC_C_SUCCESS "--c option processed"
}

# Parse arguments manually (since getopts handles only short opts, we do long)
parse_args() {
    local args=("$@")
    local i=0
    while [[ $i -lt ${#args[@]} ]]; do
        arg="${args[$i]}"
        case "$arg" in
            --c)
                i=$((i+1))
                if [[ $i -ge ${#args[@]} ]]; then
                    echo "ERROR: --c requires argument" >&2
                    cleanup $RC_C_NOARG "Missing dir for --c"
                fi
                FLAG_C="${args[$i]}"
                # Process --c immediately (should be first priority)
                handle_c_option "$FLAG_C"
                ;;
            --d)
                FLAG_D=1
                ;;
            --v)
                FLAG_V=1
                ;;
            --s)
                FLAG_S=1
                ;;
            --k)
                FLAG_K=1
                ;;
            --h)
                FLAG_H=1
                ;;
            --*)
                # Combined long options like --hvd
                if [[ "$arg" =~ ^--[dvsKhc]+$ ]]; then
                    # Split into individual letters (skip --)
                    letters="${arg:2}"
                    for ((j=0; j<${#letters}; j++)); do
                        ch="${letters:$j:1}"
                        case "$ch" in
                            d) FLAG_D=1 ;;
                            v) FLAG_V=1 ;;
                            s) FLAG_S=1 ;;
                            K) FLAG_K=1 ;;
                            h) FLAG_H=1 ;;
                            c)
                                # --c must be separate with argument, not combined
                                echo "ERROR: -c cannot be combined with other options" >&2
                                ;;
                            *) echo "WARNING: Unknown option -$ch in $arg, ignored" >&2 ;;
                        esac
                    done
                else
                    echo "WARNING: Unknown option $arg ignored" >&2
                fi
                ;;
            *)
                # Not an option starting with --, ignore (positional not expected)
                ;;
        esac
        i=$((i+1))
    done
}

# --- Flag actions (ordered: d, v, s, k, h) ----------------------------------

apply_flag_d() {
    if [[ $FLAG_D -eq 0 ]]; then
        return
    fi
    echo "--- --d mode ---"
    # Ask user for logging mode
    echo "Choose logging mode:"
    echo "1) One combined file (script_${FIO}.allout)"
    echo "2) Separate files (script_${FIO}.out and script_${FIO}.err)"
    read -p "Enter choice (1 or 2): " mode
    while [[ "$mode" != "1" && "$mode" != "2" ]]; do
        read -p "Invalid, enter 1 or 2: " mode
    done

    # Ask about existing files
    echo "Handle existing log files?"
    echo "1) Delete previous and start new"
    echo "2) Append to existing"
    read -p "Enter choice (1 or 2): " exist_mode
    while [[ "$exist_mode" != "1" && "$exist_mode" != "2" ]]; do
        read -p "Invalid, enter 1 or 2: " exist_mode
    done

    local open_mode=">"
    if [[ "$exist_mode" == "2" ]]; then
        open_mode=">>"
    fi

    # Setup filenames based on mode
    local ts="$(date '+%d-%m-%Y %H:%M:%S')"
    echo "Start time: $ts"

    if [[ "$mode" == "1" ]]; then
        LOG_ALL="script_${FIO}.allout"
        # If delete mode, truncate file
        if [[ "$exist_mode" == "1" && -f "$LOG_ALL" ]]; then
            > "$LOG_ALL"
        fi
        # Redirect stdout and stderr to tee
        exec > >(tee -a "$LOG_ALL") 2>&1
    else
        LOG_OUT="script_${FIO}.out"
        LOG_ERR="script_${FIO}.err"
        if [[ "$exist_mode" == "1" ]]; then
            [[ -f "$LOG_OUT" ]] && > "$LOG_OUT"
            [[ -f "$LOG_ERR" ]] && > "$LOG_ERR"
        fi
        # Redirect stdout and stderr separately
        exec > >(tee -a "$LOG_OUT") 2> >(tee -a "$LOG_ERR" >&2)
    fi

    # Register cleanup to print end time
    trap 'echo "End time: $(date "+%d-%m-%Y %H:%M:%S")"' EXIT
}

apply_flag_v() {
    if [[ $FLAG_V -eq 1 ]]; then
        set -x  # Print commands and arguments
    fi
}

apply_flag_s() {
    if [[ $FLAG_S -eq 0 ]]; then
        return
    fi
    # Count other instances of this script (excluding current)
    local pids=$(pgrep -f "$SCRIPT_NAME" | grep -v $$ | wc -l)
    if [[ $pids -gt 0 ]]; then
        echo "ERROR: Another instance(s) of script is running ($pids other processes)" >&2
        cleanup $RC_S_INSTANCE "Other instances detected"
    fi
}

apply_flag_k() {
    if [[ $FLAG_K -eq 0 ]]; then
        return
    fi
    echo "--- --k mode: List all script instances ---"
    local all_pids=$(pgrep -f "$SCRIPT_NAME" | sort -n)
    if [[ -z "$all_pids" ]]; then
        echo "No other instances found (only current?)"
        return
    fi
    printf "%-10s %-10s %-8s %-8s %-10s %-20s %s\n" "PID" "PPID" "UID" "GID" "TERM" "START" "COMMAND"
    for pid in $all_pids; do
        if [[ "$pid" == "$$" ]]; then
            marker=" (current)"
        else
            marker=""
        fi
        # Extract info via ps
        ps -p "$pid" -o pid=,ppid=,uid=,gid=,tty=,lstart=,args= --no-headers 2>/dev/null | while read line; do
            echo "$line$marker"
        done
        if [[ $? -ne 0 ]]; then
            ps -p "$pid" -o pid=,ppid=,uid=,gid=,tty=,start=,args= --no-headers 2>/dev/null | while read line; do
                echo "$line$marker"
            done
        fi
    done

    # Ask to kill other instances
    read -p "Do you want to terminate all OTHER instances? (y/n) " killans
    if [[ "$killans" == "y" || "$killans" == "Y" ]]; then
        read -p "Send SIGTERM (1) or SIGKILL (2)? " sig
        local signal=""
        if [[ "$sig" == "1" ]]; then
            signal="-TERM"
        elif [[ "$sig" == "2" ]]; then
            signal="-KILL"
        else
            echo "Invalid choice, skipping."
            return
        fi
        for pid in $all_pids; do
            if [[ "$pid" != "$$" ]]; then
                kill $signal "$pid" 2>/dev/null && echo "Sent signal to PID $pid"
            fi
        done
    fi
}

apply_flag_h() {
    if [[ $FLAG_H -eq 0 ]]; then
        return
    fi
    echo "--- --h mode: Help and system information ---"
    echo "Developer: Student Full Name (FIO)"
    echo "Script: $SCRIPT_NAME - Process information tool (variant 7)"
    echo "Usage: $SCRIPT_NAME [--d] [--v] [--s] [--k] [--h] [--c dir]"
    echo
    echo "System information:"
    echo "  Current date/time : $(date '+%d-%m-%Y %H:%M:%S')"
    echo "  Current directory : $(pwd)"
    echo "  Temporary file    : $TMP_FILE"
    echo "  System name       : $(uname -n)"
    echo "  Terminal          : $(tty 2>/dev/null || echo 'not a tty')"
    echo
    # User/group info
    id_output=$(id)
    echo "  RUID              : $(id -ru) ($(id -run))"
    echo "  EUID              : $(id -u) ($(id -un))"
    echo "  RGID              : $(id -rg) ($(id -rgn))"
    echo "  EGID              : $(id -g) ($(id -gn))"
    if [[ $(id -u) -eq 0 ]]; then
        echo "  ** WARNING: Script is run as superuser (UID=0) **"
    fi
    if [[ $(id -g) -eq 0 ]]; then
        echo "  ** WARNING: Script is run with group administrators (GID=0) **"
    fi
    echo
    echo "Script file information:"
    echo "  PID of this process : $$"
    echo "  Script name         : $SCRIPT_NAME"
    echo "  Relative/Abs path   : $0"
    echo "  Full absolute path  : $(realpath "$0" 2>/dev/null || echo "$SCRIPT_PATH_ABS")"
    echo "  Command line        : $(ps -p $$ -o args= 2>/dev/null)"
    # stat information
    if [[ -f "$0" ]]; then
        stat_out=$(stat -c "  Size: %s bytes, Permissions: %A (%a), Modified: %y, Owner: %U (%u), Group: %G (%g)" "$0" 2>/dev/null)
        echo "$stat_out"
    fi

    # Ask user whether to continue or exit
    echo
    read -p "Continue normal script execution? (y) or exit? (n): " cont
    if [[ "$cont" != "y" && "$cont" != "Y" ]]; then
        cleanup $RC_H_EXIT "Exiting after --h"
    fi
}

# --- Menu functions (main functionality) -------------------------------------

menu() {
    while true; do
        echo
        echo "===== Process Information Menu ====="
        echo "1) Show current directory"
        echo "2) Change directory"
        echo "3) List all processes"
        echo "4) List processes by user"
        echo "5) List processes by group"
        echo "6) List processes by terminal"
        echo "7) Show detailed info for a PID"
        echo "8) Exit"
        read -p "Enter choice [1-8]: " choice

        case "$choice" in
            1)
                echo "Current directory: $(pwd)"
                ;;
            2)
                read -p "Enter new directory path (or empty to cancel): " newdir
                if [[ -n "$newdir" ]]; then
                    change_directory "$newdir"
                fi
                ;;
            3)
                list_processes "all"
                ;;
            4)
                read -p "Enter username: " user
                if [[ -n "$user" ]]; then
                    list_processes "user" "$user"
                fi
                ;;
            5)
                read -p "Enter group name or GID: " group
                if [[ -n "$group" ]]; then
                    list_processes "group" "$group"
                fi
                ;;
            6)
                read -p "Enter terminal (e.g., pts/0, tty1): " term
                if [[ -n "$term" ]]; then
                    list_processes "terminal" "$term"
                fi
                ;;
            7)
                read -p "Enter PID: " pid
                if [[ -n "$pid" && "$pid" =~ ^[0-9]+$ ]]; then
                    show_process_info "$pid"
                else
                    echo "Invalid PID"
                fi
                ;;
            8)
                cleanup 0 "User exit from menu"
                ;;
            *)
                echo "Invalid choice, please enter 1-8"
                ;;
        esac
    done
}

# --- Main --------------------------------------------------------------------

# Set traps
trap handle_sigint SIGINT
trap handle_sigquit SIGQUIT
trap handle_sigterm SIGTERM
trap handle_sigusr1 SIGUSR1
trap handle_sigusr2 SIGUSR2

# Parse command line arguments (this may exit if --c is given)
parse_args "$@"

# Create temporary file (after trap is set)
TMP_FILE="$(mktemp -p "$TMP_DIR" "${SCRIPT_NAME}_${FIO}_XXXXXX.tmp")"
check_error "mktemp"
if [[ ! -f "$TMP_FILE" ]]; then
    echo "FATAL: Cannot create temporary file" >&2
    exit 1
fi

# Write startup info to temp file
{
    echo "Script file: $SCRIPT_NAME"
    echo "PID: $$"
    echo "Start time: $START_TIME_RAW"
} > "$TMP_FILE"

# Apply flags in order (--d, --v, --s, --k, --h)
apply_flag_d
apply_flag_v
apply_flag_s
apply_flag_k
apply_flag_h

# Start main menu
menu

# Should not reach here, but just in case
cleanup 0 "Normal end"
